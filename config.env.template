# =============================================================================
# Perpetual Inventory Engine - Configuration Template
# =============================================================================
# Copy this file to config.env and fill in your workspace-specific values:
#   cp config.env.template config.env
#
# Then source it before running any scripts:
#   source config.env
# =============================================================================

# ── Databricks Workspace ─────────────────────────────────────────────────────
export DATABRICKS_HOST="https://YOUR_WORKSPACE_ID.N.gcp.databricks.com"
export DATABRICKS_PROFILE="my-pi-profile"
export DATABRICKS_USER="your.name@databricks.com"

# ── SQL Warehouse ─────────────────────────────────────────────────────────────
# Find via: databricks warehouses list --profile $DATABRICKS_PROFILE
export DATABRICKS_WAREHOUSE_ID="YOUR_WAREHOUSE_ID"

# ── Unity Catalog ─────────────────────────────────────────────────────────────
export PI_CATALOG="perpetual_inventory_engine"

# ── Lakeflow Pipeline ────────────────────────────────────────────────────────
export PIPELINE_NAME="perpetual-inventory-pipeline"
export PIPELINE_TARGET_SCHEMA="gold"

# ── Vector Search ─────────────────────────────────────────────────────────────
export VS_ENDPOINT_NAME="perpetual-inventory-vs-endpoint"
export VS_INDEX_NAME="${PI_CATALOG}.gold.anomaly_summary_vs_index"
export VS_EMBEDDING_MODEL="databricks-gte-large-en"

# ── Foundation Model ──────────────────────────────────────────────────────────
export SERVING_ENDPOINT="databricks-claude-sonnet-4-5"

# ── Databricks App ────────────────────────────────────────────────────────────
export APP_NAME="perpetual-inventory-app"
export APP_WORKSPACE_PATH="/Workspace/Users/${DATABRICKS_USER}/${APP_NAME}"
